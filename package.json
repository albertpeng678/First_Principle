{
  "name": "pm-drill",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node -r dotenv/config server.js",
    "dev": "node -r dotenv/config --watch server.js",
    "test": "jest",
    "test:e2e": "npx playwright test --config=tests/playwright/playwright.config.js",
    "cleanup:empty-sessions": "node scripts/cleanup-empty-sessions.js",
    "cleanup:empty-sessions:dry-run": "node scripts/cleanup-empty-sessions.js --dry-run",
    "test:adversarial": "playwright test tests/adversarial/ --reporter=list",
    "test:race-regression": "playwright test tests/visual/draft-data-loss-fix.spec.js tests/visual/preflight-session-creation.spec.js tests/visual/drill-step-default-fix.spec.js --config tests/visual/playwright.config.js --project Desktop-1280 --reporter=line",
    "setup-hooks": "ln -sf ../../scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x scripts/hooks/pre-commit && echo 'pre-commit hook installed (.git/hooks/pre-commit -> scripts/hooks/pre-commit)'",
    "test:e2e:gate": "playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:gate:ui": "playwright test --config tests/e2e/playwright.config.js --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.34.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^30.3.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "supertest": "^7.2.2"
  }
}
