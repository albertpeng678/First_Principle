#!/usr/bin/env bash
# pre-commit — race regression smoke for draft persistence
#
# Triggers ONLY when public/app.js diff touches save/restore/preflight surface.
# Spins up dev server, runs draft-data-loss-fix + preflight specs on Desktop-1280
# (~20 sec total). Kills server on exit.
#
# Bypass with `git commit --no-verify` if you intentionally need to skip.
# Install via `npm run setup-hooks` (idempotent symlink to .git/hooks/pre-commit).

set -u

# --- BEGIN: Stage 0 B7 prevention — block hardcoded prod URL / real email in test specs ---
STAGED_SPECS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^tests/.*\.(spec|test)\.js$' || true)
if [ -n "$STAGED_SPECS" ]; then
  PROD_URL_HITS=""
  EMAIL_HITS=""
  while IFS= read -r f; do
    if [ -n "$f" ] && grep -q 'railway\.app' "$f" 2>/dev/null; then
      PROD_URL_HITS="${PROD_URL_HITS}${f}\n"
    fi
    if [ -n "$f" ] && grep -qE '[a-zA-Z0-9._%+-]+@gmail\.com' "$f" 2>/dev/null; then
      EMAIL_HITS="${EMAIL_HITS}${f}\n"
    fi
  done <<< "$STAGED_SPECS"

  if [ -n "$PROD_URL_HITS" ]; then
    echo "ERROR: hardcoded prod URL (railway.app) found in spec file(s):"
    printf "$PROD_URL_HITS" | sed 's/^/  - /'
    echo "Use process.env.BASE_URL instead."
    exit 1
  fi
  if [ -n "$EMAIL_HITS" ]; then
    echo "ERROR: hardcoded real-looking email (@gmail.com) found in spec file(s):"
    printf "$EMAIL_HITS" | sed 's/^/  - /'
    echo "Use process.env.TEST_EMAIL (which points to e2e@first-principle.test)."
    exit 1
  fi
fi
# --- END: Stage 0 B7 prevention ---

# Skip if public/app.js not staged
if ! git diff --cached --name-only --diff-filter=ACMR | grep -q "^public/app\.js$"; then
  exit 0
fi

# Skip if staged diff doesn't touch the save/restore/preflight/draft-mode code path
# Includes (a) save/persistence helpers (b) restore/load helpers (c) AppState fields
# tied to draft session creation (d) mode/qcard click handlers that gate session
# tuple identity (mode + drill_step → backend idempotent guard key).
SENTINEL_RE='(triggerSaveCycle|persistDraft|persistBackend|ensureCirclesDraftSession|restoreCirclesPhase1FromSession|loadCirclesSessionFromHistory|preflightDraftSession|circlesFrameworkDraft|circlesPhase1Solutions|circlesDrillStep|circlesMode|circlesSelectedQuestion|qcard-confirm|data-circles-mode|populateTextareasFromDraft|loadDraftFor|renderOffcanvasItem)'
if ! git diff --cached public/app.js | grep -qE "$SENTINEL_RE"; then
  exit 0
fi

echo "→ pre-commit: race regression smoke (public/app.js critical path touched)"

PORT=4000
SERVER_LOG=/tmp/pmdrill-precommit-server.log
SERVER_PID_FILE=/tmp/pmdrill-precommit-server.pid

# Kill any stale server first
if [ -f "$SERVER_PID_FILE" ]; then
  OLD_PID=$(cat "$SERVER_PID_FILE" 2>/dev/null || true)
  if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
    kill "$OLD_PID" 2>/dev/null || true
  fi
  rm -f "$SERVER_PID_FILE"
fi

# Start dev server in background
PORT=$PORT node server.js > "$SERVER_LOG" 2>&1 &
SERVER_PID=$!
echo $SERVER_PID > "$SERVER_PID_FILE"

# Always cleanup
cleanup() {
  if [ -n "${SERVER_PID:-}" ]; then
    kill "$SERVER_PID" 2>/dev/null || true
  fi
  rm -f "$SERVER_PID_FILE"
}
trap cleanup EXIT

# Wait for server ready (max 15 sec)
READY=0
for i in $(seq 1 15); do
  if curl -fs -o /dev/null "http://localhost:$PORT/"; then
    READY=1
    break
  fi
  sleep 1
done

if [ $READY -ne 1 ]; then
  echo "✗ pre-commit: dev server failed to start on port $PORT (see $SERVER_LOG)"
  exit 1
fi

# Run target specs Desktop-1280 only (~20 sec)
PLAYWRIGHT_FORCE_TTY=0 FORCE_COLOR=0 npx playwright test \
  tests/visual/draft-data-loss-fix.spec.js \
  tests/visual/preflight-session-creation.spec.js \
  tests/visual/drill-step-default-fix.spec.js \
  --config tests/visual/playwright.config.js \
  --project Desktop-1280 \
  --reporter=line 2>&1 | tail -16

EXIT=$?

if [ $EXIT -ne 0 ]; then
  echo ""
  echo "✗ pre-commit: race regression FAILED."
  echo "  Investigate before committing — this is the P0 draft data loss surface."
  echo "  Bypass with --no-verify ONLY if you fully understand the risk."
  exit 1
fi

echo "✓ pre-commit: race regression OK"
exit 0
