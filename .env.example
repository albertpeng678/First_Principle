# 3-env split (all gitignored):
#   .env           — main app secrets + USER_REAL_EMAIL (cleanup-mode identity)
#   .env.local     — local-dev fixture config (BASE_URL=localhost)
#   .env.test      — prod-UAT fixture config (BASE_URL=railway.app)
# Scripts load .env first, then .env.test/.env.local with override:false.

# === goes in .env ===
# OPENAI_API_KEY=...
# SUPABASE_URL=...
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_ANON_KEY=...
# PORT=4000
USER_REAL_EMAIL=<your real account email; only used by scripts/execute-cleanup.js>

# === goes in .env.local or .env.test ===
BASE_URL=<http://localhost:3000 OR https://first-principle.up.railway.app/>
TEST_EMAIL=<e2e@first-principle.test>
TEST_PASSWORD=<set via scripts/register-test-account.js; 16-char random>
